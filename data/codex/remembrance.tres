[ext_resource type="Script" path="res://scripts/data/codex_entry.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"remembrance"
title = "Remembrance, Litany, and the Trance"
order_index = 3
body = "The abilities in this game borrow their names from real practice. A litany is a set devotion returned to daily, the way a river returns to its bed. Remembrance is the heart of the whole path: the practice of keeping the Divine in mind until forgetting becomes the stranger and remembering becomes home. And what the game calls a Trance points at something the tradition describes carefully — a state that arrives as a gift, not a possession, lifting the traveler briefly beyond their own strength.\n\nFervor, the golden bar that fills as your companions endure, is their aspiration — the will that gathers until it overflows."
links = ["The teachings that inspired this game | https://nurmuhammad.com"]
