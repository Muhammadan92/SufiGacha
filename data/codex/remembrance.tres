[ext_resource type="Script" path="res://scripts/data/codex_entry.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"remembrance"
title = "Remembrance, Litany, and the Trance"
order_index = 3
body = "In this world, a litany is a small devotion returned to daily, the way a river returns to its bed. Remembrance is the practice of keeping the Light in mind until forgetting becomes the stranger and remembering becomes home. And a Trance is a state that arrives as a gift, never a possession — lifting a companion briefly beyond their own strength. Fervor, the golden bar, is aspiration gathering until it overflows. These are fantasy mechanics — but their names were borrowed from a real vocabulary of the heart, and the threads below lead to it."
links = ["The teachings that inspired this game | https://nurmuhammad.com"]
