[ext_resource type="Script" path="res://scripts/data/codex_entry.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"moon_04"
title = "The Straight Path"
order_index = 13
body = "In the fourth season the wayfarers speak of a road that runs true — the straight path, opening through the heart. What was born in the third season begins to blossom in the fourth. Its number is thirty-six. A season for tending what has newly begun: young companions, fresh masteries, first steps on the Path."
links = ["Teachings of the Fourth Moon | https://nurmuhammad.com/4-rabiul-thani/"]
