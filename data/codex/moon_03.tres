[ext_resource type="Script" path="res://scripts/data/codex_entry.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"moon_03"
title = "The Kingdom"
order_index = 12
body = "The third season carries the year's gentlest weight. The old songs of this world remember a birth in it — a light, they say, from which every other light was kindled, and with it a Kingdom not made of land. Its number is twenty-seven. The rose companies keep this season with songs of welcome."
links = ["Teachings of the Third Moon | https://nurmuhammad.com/3-rabiul-awwal/", "The Birth that Began Creation | https://nurmuhammad.com/the-birth-of-prophet-muhammad-s-is-the-birth-of-creation/"]
