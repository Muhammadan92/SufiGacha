[resource]
script = ExtResource("1")
id = &"moon_10"
title = "The Binary Code"
order_index = 19
body = "The tenth season carries a secret hidden in plain sight: ten is a one and a dot — the same two signs this world calls binary code, the language running beneath every machine. The teachings say the code's truth is not one-and-zero but on and off; and deeper still, that there is no off — everything is always receiving. The traveler's work in this season is to become the dot: small as dust before the One, for only the dot stands in that presence without adding to it. The season opens with festival — rejoice, give thanks, then practice becoming nothing."
links = ["Teachings of the Tenth Season | https://nurmuhammad.com/10-shawwal/", "The Power of 10 and the Binary Code | https://nurmuhammad.com/shawwal-power-of-the-number-10-binary-code/"]
