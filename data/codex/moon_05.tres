[resource]
script = ExtResource("1")
id = &"moon_05"
title = "The Kneeling"
order_index = 14
body = "The fifth season is named for kneeling — the posture of the dry months, when nothing seems to grow and the traveler bows and walks on anyway. In this world it is a season of teachers: the great guides of the golden chain are remembered in it, those who endured until endurance itself became sweet. Its number is forty-five."
links = ["Teachings of the Fifth Moon | https://nurmuhammad.com/5-jummadal-awwal/"]
