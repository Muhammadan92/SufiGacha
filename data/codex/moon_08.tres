[resource]
script = ExtResource("1")
id = &"moon_08"
title = "The Beloved"
order_index = 17
body = "The eighth season belongs to the Beloved — so the old songs name it — and its middle night is kept as a night of mercy, when destinies for the coming year are said to be written anew. Its number is seventy-two. Everything in this season leans forward: provisions gathered, hearts swept clean, lamps trimmed for the Light to come."
links = ["Teachings of the Eighth Moon | https://nurmuhammad.com/tag/shaban/"]
