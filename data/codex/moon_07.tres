[ext_resource type="Script" path="res://scripts/data/codex_entry.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"moon_07"
title = "The Ascent"
order_index = 16
body = "In the seventh season, it is told, the road turns upward. The old accounts remember a night journey beyond the highest veil, and the wayfarers hold that some ascent is offered to every heart in this season, each according to its longing. Its number is sixty-three. Climb the Minaret while the season lasts."
links = ["Teachings of the Seventh Moon | https://nurmuhammad.com/7-rajab/", "Three Moons of Opportunity | https://nurmuhammad.com/immense-opportunities-next-3-months-rajab-shaban-ramadan/"]
