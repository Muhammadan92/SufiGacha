[ext_resource type="Script" path="res://scripts/data/codex_entry.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"moon_01"
title = "The Door"
order_index = 10
body = "The year of this world opens through a door. The first season is kept sacred: in the oldest truces no fighting was permitted in it, and so the wayfarers begin their year with restraint — honoring beginnings by guarding them. Its number in the old count is nine, the first veil of the year. The Door opens each new season-year of Seven Springs."
links = ["Teachings of the First Moon | https://nurmuhammad.com/1-muharram/"]
