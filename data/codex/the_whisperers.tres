[ext_resource type="Script" path="res://scripts/data/codex_entry.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"the_whisperers"
title = "The Whisperers and the Ego"
order_index = 4
body = "The enemies of this world are not people, and never will be. They are the whisperers — small gnawing voices of doubt — and behind them the great adversary: the ego, the commanding self, tamed only valley by valley. It does not fight fair. It flatters, it delays, it argues. It grows grander the closer you come to the end of the road — which is why the final Vice wears a crown. Pride can wear even your victories."
links = []
