[resource]
script = ExtResource("1")
id = &"moon_06"
title = "The Moon"
order_index = 15
body = "The sixth season carries the calendar's own name: the moon, which rules every month of this world's year. It is the second season of hardened ground, and the wayfarers say the second half of any hardship is where its treasure hides — springs buried under stone, found only by those who keep digging. Its number is fifty-four. The year's midpoint: half the veils behind, half ahead."
links = ["Teachings of the Sixth Moon | https://nurmuhammad.com/6-jumadal-thani/"]
