[ext_resource type="Script" path="res://scripts/data/codex_entry.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"the_path"
title = "The Orders of the Path"
order_index = 1
body = "Everything in this Notebook is a story — but the stories were inspired by something real. The orders of Seven Springs are fantasy companies modeled on real schools of the inner path: one famed for silence, one for thunderous remembrance, one for the whirling turn, one for the open table, one for litanies of the sea, one for bodies made unshakeable, one for the science of light. This game is not their teacher and claims no authority — it is a signpost wearing a costume. Every character is fictional. The inspirations are linked below, and they reward curiosity far better than we can."
links = ["The teachings that inspired this game | https://nurmuhammad.com"]
