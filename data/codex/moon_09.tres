[resource]
script = ExtResource("1")
id = &"moon_09"
title = "The Light"
order_index = 18
body = "The ninth moon is the crown of the year. The travelers fast its days — hunger of the body, feast of the soul — and seek near its end a hidden night said to outweigh years of ordinary time. Its number is eighty-one, nine times nine: light upon light. In Seven Springs this is the generosity season: gifts given, burdens lightened, nothing sold with pressure."
links = ["Teachings of the Ninth Moon | https://nurmuhammad.com/9-ramadan/"]
