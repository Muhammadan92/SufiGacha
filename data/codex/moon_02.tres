[resource]
script = ExtResource("1")
id = &"moon_02"
title = "The Cave"
order_index = 11
body = "The second season belongs to the road and to the cave. It is told that companions once fled a corrupt age and slept for lifetimes in a cave, sheltered under mercy — and the wayfarers of this world keep the lesson close: when the way darkens, run to the cave of safety, and let mercy find you there. Its number is eighteen: nine, doubled."
links = ["Teachings of the Second Moon | https://nurmuhammad.com/2-safar/", "The Cave and the Realities of 18 | https://www.nurmuhammad.com/safar-and-the-cave-realities-of-18-the-heart-of-the-divine/"]
