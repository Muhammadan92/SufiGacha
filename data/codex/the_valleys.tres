[ext_resource type="Script" path="res://scripts/data/codex_entry.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"the_valleys"
title = "The Seven Valleys"
order_index = 2
body = "Long ago — in our world, not the game's — a poet wrote of thirty birds who crossed seven valleys to find their King, and found a mirror. Seven Springs borrows its road from that poem: the Quest, Love, Knowledge, Detachment, Unity, Wonder, and last a valley where the self is given up entirely. In the game, as in the poem, the demons grow more personal the deeper you go — the farther inward the road turns, the more the enemy looks like you."
links = []
