[ext_resource type="Script" path="res://scripts/data/codex_entry.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"moon_11"
title = "The Shaking"
order_index = 20
body = "The eleventh season is named for the earthquake: nine elevens are ninety-nine, and the ninety-ninth chapter is the Shaking. The teachings say what is hidden in the earth comes out only when the earth is shaken — and the soul is no different: every buried reality waits for the tremor that brings it to light. Eleven is also the Divine Mirror, one standing before one. So the travelers meet this season's shaking as a mercy: hold to patience — the ninety-ninth name — and let what is hidden in you be shaken loose and shown."
links = ["Teachings of the Eleventh Season | https://nurmuhammad.com/dhulqidah/", "The Divine Mirror and the Power of 99 | https://nurmuhammad.com/divine-mirror-realities-of-11-power-of-99-zalzalah-earthquake/"]
