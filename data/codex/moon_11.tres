[ext_resource type="Script" path="res://scripts/data/codex_entry.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"moon_11"
title = "The Shaking"
order_index = 20
body = "The eleventh season is named for the earthquake of the old count: nine elevens are ninety-nine, and its chapter is the Shaking. What is hidden in the earth comes out only when the earth is shaken — and the soul, the wayfarers say, is no different: every buried reality waits for the tremor that brings it to light. Eleven is also the mirror, one standing before one. Meet the tremor as a mercy: hold to patience, and let what is hidden in you be shown."
links = ["Teachings of the Eleventh Season | https://nurmuhammad.com/dhulqidah/", "The Divine Mirror and the Power of 99 | https://nurmuhammad.com/divine-mirror-realities-of-11-power-of-99-zalzalah-earthquake/"]
