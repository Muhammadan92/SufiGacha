[ext_resource type="Script" path="res://scripts/data/codex_entry.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"the_guardians"
title = "The Guardians — Dragons of Light"
order_index = 5
body = "In Seven Springs, dragons fight beside you. Each is the ancient protector of one of the seven springs, and their power is guarding and the devouring of falsehood — never conquest. We did not invent the image from nothing: we found old accounts of protecting dragons, and of a staff that became a great serpent and swallowed every illusion the sorcerers had spun — and we built a fantasy on that foundation. Seven springs; seven Guardians. You have met the first. Where we found the image is linked below."
links = ["Spiritual Dragons Protecting Believers | https://nurmuhammad.com/spiritual-dragons-protecting-believers-sufi-meditation-center/?playlist=17074", "Thuban and the Fiery Guardian | https://nurmuhammad.com/thuban-and-the-fiery-guardian-sayyidina-malik-as/"]
