[resource]
script = ExtResource("1")
id = &"moon_12"
title = "The Fountain"
order_index = 21
body = "The twelfth season completes the count: twelve nines are one hundred and eight, and at the hundred-and-eighth step stands the Fountain — the inexhaustible gift at the end of every true road. Pilgrims of this world travel in it; the year pours itself out and is refilled. Where the Seven Valleys end, this season points. One day, the game will take you there."
links = ["Teachings of the Twelfth Moon | https://nurmuhammad.com/12-dhul_hijjah/", "The Mystical Number 108 | https://nurmuhammad.com/mystical-number-108-kawthar-haq-and-reality-of-sacrifice/"]
